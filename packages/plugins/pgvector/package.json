{
	"name": "@emdash-cms/plugin-pgvector",
	"private": true,
	"version": "0.0.1",
	"description": "Postgres pgvector backend for embeddings + similarity search. HNSW index, configurable dimension, optional auto-embed-on-save. Postgres-only by design — no SQLite fallback.",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./sandbox": "./src/sandbox-entry.ts",
		"./client": "./src/client.ts"
	},
	"files": [
		"src"
	],
	"keywords": [
		"emdash",
		"cms",
		"plugin",
		"pgvector",
		"embeddings",
		"vector-search"
	],
	"license": "MIT",
	"scripts": {
		"test": "vitest run"
	},
	"peerDependencies": {
		"emdash": "workspace:>=0.7.0"
	},
	"dependencies": {
		"@emdash-cms/plugin-tools": "workspace:*",
		"pg": "^8.0.0"
	},
	"devDependencies": {
		"@types/pg": "^8.16.0",
		"vitest": "catalog:"
	}
}
