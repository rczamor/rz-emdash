		"src"
	],
	"keywords": [
		"emdash",
		"cms",
		"plugin",
		"pgvector",
		"embeddings",
		"vector-search"
	],
	"license": "MIT",
	"peerDependencies": {
		"emdash": "workspace:>=0.7.0"
	},
	"dependencies": {
		"pg": "^8.0.0",
		"@emdash-cms/plugin-tools": "workspace:*"
	},
	"devDependencies": {},
	"optionalDependencies": {}
}
