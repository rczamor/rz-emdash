	"keywords": ["emdash", "cms", "plugin", "mcp", "model-context-protocol"],
	"license": "MIT",
	"scripts": {
		"test": "vitest run"
	},
	"peerDependencies": {
		"emdash": "workspace:>=0.7.0"
	},
	"dependencies": {
		"@emdash-cms/plugin-tools": "workspace:*"
	},
	"devDependencies": {
		"vitest": "catalog:"
	},
	"optionalDependencies": {}
