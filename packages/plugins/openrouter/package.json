{
	"name": "@emdash-cms/plugin-openrouter",
	"private": true,
	"version": "0.0.1",
	"description": "OpenRouter gateway for EmDash. Connects the CMS to any LLM (Anthropic, OpenAI, Google, etc.) via a single API key. Exposes chat/complete/embeddings routes and registers llm:* automation actions.",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./sandbox": "./src/sandbox-entry.ts",
		"./client": "./src/client.ts"
	},
	"files": [
		"src"
	],
	"keywords": [
		"emdash",
		"cms",
		"plugin",
		"openrouter",
		"llm",
		"ai"
	],
	"license": "MIT",
	"peerDependencies": {
		"emdash": "workspace:>=0.7.0"
	},
	"dependencies": {
		"@emdash-cms/plugin-automations": "workspace:*",
		"@emdash-cms/plugin-tokens": "workspace:*"
	},
	"devDependencies": {},
	"optionalDependencies": {}
}
